#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# Colorized aliases
alias ls='ls --color=auto'
alias grep='grep --color=auto'

# Unknown
PS1='[\u@\h \W]\$ '

# Set default programs
export EDITOR="helix"
export TERMINAL="foot"
export BROWSER="firefox"

# Add Godot Version Manager to path
export PATH="/home/jking/.gdvm/bin/current_godot:/home/jking/.gdvm/bin:$PATH"


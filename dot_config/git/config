[user]
    email = codazendev@gmail.com
    name = Jeremy King

[init]
    # Tell git to use 'main' instead of 'master' for default branches
    defaultBranch = main

[alias]
    # Alias for switching config to codazendev account
    usec = !git config user.name 'Jeremy King' && git config user.email 'codazendev@gmail.com'
    # Alias for switching config to jgkingdev account
    usej = !git config user.name 'Jeremy King' && git config user.email 'jeremykingdev@gmail.com'

    # Alias for cloning with codazendev account
    cone = !sh -c 'git clone "$1" && cd $(basename $1 .git) && git usec' -
    # Alias for cloning with jgkingdev account
    jone = !sh -c 'git clone "$1" && cd $(basename $1 .git) && git usej' -

[pull]
    rebase = true

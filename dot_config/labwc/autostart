# Labwc autostart file

runsvdir ~/.runit/runsvdir &

# wallpapers
wpaperd -d

# displays
kanshi >/dev/null 2>&1 &

# statusbar
waybar --log-level off &

# notifications
mako >/dev/null 2>&1 &

# lock screen after 5 minutes and turn off display after another 5 minutes
swayidle -w \
    timeout 300 'swaylock -f -c 000000' \
    timeout 600 'pkill kanshi ; wlopm --off \*' \
    resume 'kanshi & wlopm --on \*' \
    before-sleep 'swaylock -f -c 000000' >/dev/null 2>&1 &

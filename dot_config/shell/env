#!/bin/sh
# $XDG_CONFIG_HOME/shell/env
# Use this file to set environment variables that should be available to other programs (e.g. EDITOR, XDG_CONFIG_HOME, PATH).

# Set default programs
export EDITOR=helix
export TERMINAL=foot
export BROWSER=firefox

# Set XDG directories
export XDG_CACHE_HOME=$HOME/.cache
export XDG_CONFIG_HOME=$HOME/.config
export XDG_DATA_HOME=$HOME/.local/share
export XDG_STATE_HOME=$HOME/.local/state

# Add '~/.local/bin' subdirectories to path
for d in ~/.local/bin/*; do
    PATH+=":$d"
done

# GDVM
export PATH=$PATH:$HOME/.gdvm/bin
export PATH=$PATH:$HOME/.gdvm/bin/current_godot

